PORT=4000
PAGE=1
LIMIT=20

DATABASE_URL="postgresql://user:password@$host/name_ddbb?sslmode=ddbb_ssl_mode"
# DIRECT_URL: endpoint NO pooled (sin "-pooler" en el host de Neon). Requerido para `prisma migrate`,
# que no funciona a través de PgBouncer. Opcional si tu DATABASE_URL ya es directa (Postgres local/CI).
DIRECT_URL="postgresql://user:password@$host/name_ddbb?sslmode=ddbb_ssl_mode"

SECRET_JWT="acavaunsecretotuyo"
SECRET_JWT_REFRESH="otro-secreto-distinto-al-de-arriba"

PORT_ORIGIN_WEBSOCKET="http://localhost:4200"

# --- Nuevas variables (todas con default si se omiten, ver src/config/envs.ts) ---
NODE_ENV=development

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# COOKIE_DOMAIN: dejar VACIO si frontend y backend están en dominios distintos (ej. Netlify + Render).
# Sólo setear si ambos comparten el mismo eTLD+1 (ej. ".tudominio.com").
COOKIE_DOMAIN=

# Pool de conexiones de Prisma (se inyectan en el query string de DATABASE_URL):
#   Neon pooler (host con "-pooler"): DB_CONNECTION_LIMIT=5, DB_PGBOUNCER=true
#   Postgres local / CI:              DB_CONNECTION_LIMIT=10, DB_PGBOUNCER=false
DB_CONNECTION_LIMIT=5
DB_POOL_TIMEOUT=20
DB_CONNECT_TIMEOUT=15
DB_PGBOUNCER=true

SHUTDOWN_TIMEOUT_MS=15000

THROTTLE_TTL=60000
THROTTLE_LIMIT=200
CACHE_TTL=30000